{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the JOAmedic system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["USER", "ADMIN"] },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer",
      "type": "object",
      "properties": {
        "customerInfo": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "country": { "type": "string" },
            "city": { "type": "string" },
            "address": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "items": {
          "type": "array"
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "trackingNumber": { "type": "string" },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["customerInfo", "items", "total", "status", "createdAt", "userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
