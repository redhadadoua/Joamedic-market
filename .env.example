# Environment Configuration

# Required for Google Sheets Webhook (Apps Script)
# Customers checkout -> sends POST to this webhook
VITE_GOOGLE_WEBHOOK_URL="YOUR_GOOGLE_APPS_SCRIPT_WEB_APP_URL"

# Required if Admin wants to use Workspace Direct Sync
VITE_GOOGLE_SHEET_ID="YOUR_SPREADSHEET_ID_HERE"

# Required for Meta Pixel (Facebook Pixel) integration
VITE_META_PIXEL_ID="YOUR_PIXEL_ID_HERE"
